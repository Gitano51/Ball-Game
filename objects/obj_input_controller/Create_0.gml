/// @description Default keybinding
default_key_right = vk_right;
default_key_left = vk_left;
default_key_up = vk_up;
default_key_down = vk_down;
default_key_jump = vk_space;

//Using default keys as actions
action_right = default_key_right;
action_left = default_key_left;
action_up = default_key_up;
action_down = default_key_down;
action_jump = default_key_jump;

//Definitions of control variables
is_action_right_checked = false;
is_action_left_checked = false;
is_action_up_checked = false;
is_action_down_checked = false;
is_action_jump_checked = false;

is_action_up_pressed = false;
is_action_jump_pressed = false;

is_action_up_released = false;
is_action_jump_released = false;

is_jump_pressed = false;
is_jump_released = false;